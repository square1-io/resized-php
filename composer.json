{
    "name": "square1/resized",
    "type": "library",
    "description": "On-demand image manipulation service.",
    "keywords": [
        "square1",
        "resized",
        "image manipulation"
    ],
    "homepage": "https://github.com/square1-io/resized-php",
    "license": "MIT",
    "authors": [
        {
            "name": "Ciaran Maher",
            "email": "ciaran@square1.io",
            "homepage": "https://www.resized.co"
        },
        {
            "name": "Jose Vicente Orts",
            "email": "vince@square1.io"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0|^13.0",
        "friendsofphp/php-cs-fixer": "^3.95.0"
    },
    "autoload": {
        "psr-4": {
            "Square1\\Resized\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Square1\\Resized\\Test\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "format": "php-cs-fixer fix --allow-risky=yes",
        "format:check": "php-cs-fixer check --allow-risky=yes"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.0-dev"
        }
    }
}
